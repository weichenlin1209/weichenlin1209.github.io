---
import ChipLayout from "../../../layouts/ChipLayout.astro";
import { GetCategories } from "../../../utils/content";

const categories = await GetCategories("zh");
const chips = Array.from(categories.entries()).map(([key, value]) => ({
  name: value.name,
  slug: value.slug,
  count: value.posts.length,
}));
---

<ChipLayout chips={chips} title="分類" baseUrl="/zh" />