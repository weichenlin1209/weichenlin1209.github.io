---
import ChipLayout from "../../../layouts/ChipLayout.astro";
import { GetTags } from "../../../utils/content";

const tags = await GetTags("zh");
const chips = Array.from(tags.entries()).map(([key, value]) => ({
  name: value.name,
  slug: value.slug,
  count: value.posts.length,
}));
---

<ChipLayout chips={chips} title="標籤" baseUrl="/zh" />