---
import { getEntry, render } from "astro:content";
import Main from "../../layouts/MainLayout.astro";
import Markdown from "../../components/Markdown.astro";
import games from "../../contents/en/specs/games.json";

const entry = await getEntry("specs_en", "about");
const { Content } = await render(entry!);

const gameEntry = await getEntry("specs_en", "game");
const { Content: GameContent } = await render(gameEntry!);
---

<Main lang="en" title={entry!.data.title}>
  <div class="article-wrapper">
    <div class="article">
      <Markdown>
        <Content />
      </Markdown>
    </div>
  </div>

  <div class="game-wrapper">
    <div class="game-header article">
      <Markdown>
        <GameContent />
      </Markdown>
      <div class="game-grid mt-8">
        {games.map((game) => (
          <a class="game-card" href={game.link} target="_blank" rel="noopener noreferrer">
            {game.img && <img class="game-cover" src={game.img} alt={game.title} loading="lazy" />}
          </a>
        ))}
      </div>
      <div class="game-disclaimer">
        All game covers, trademarks, and related images displayed on this page belong to their <strong>respective owners</strong>. This is for non-profit sharing and identification purposes only.
      </div>
    </div>
  </div>
</Main>

<style>
  .article-wrapper {
    @apply w-full rounded-2xl bg-[var(--card-color)] p-10;
  }
  .article {
    @apply flex flex-col;
  }
  .game-wrapper {
    @apply mt-8 rounded-2xl bg-[var(--card-color)] p-10;
  }
  .game-header {
    @apply mb-6 flex flex-col;
  }
  .game-grid {
    @apply grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5;
  }
  .game-card {
    @apply flex flex-col overflow-hidden rounded-xl bg-[var(--card-color)] transition-all;
  }
  .game-card:hover {
    background-color: var(--primary-color-lighten);
    transform: scale(1.05);
  }
  .game-cover {
    @apply aspect-[3/4] w-full rounded-xl object-cover;
  }
  .game-disclaimer {
    @apply mt-8 px-4 py-4 text-center text-gray-500 whitespace-normal break-words;
  }
</style>