---
import { Icon } from "astro-icon/components";

export interface Props {
  name: string;
  link: string;
  baseUrl?: string;
}
const { name, link, baseUrl = "" } = Astro.props;

let finalLink = link;
if (name === "line-md:rss" && baseUrl) {
  finalLink = `${baseUrl}/rss.xml`;
}
---

<a href={finalLink} target={name === "line-md:rss" ? "_self" : "_blank"}>
  <div
    class="flex h-10 w-10 flex-col justify-center rounded-lg transition-all hover:brightness-75 dark:hover:brightness-125"
  >
    <div class="flex flex-row justify-center">
      <Icon name={name} size={24} class="text-[var(--primary-color)]" />
    </div>
  </div>
</a>